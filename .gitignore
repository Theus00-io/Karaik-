# =============================================================================
# KaraoKê Queue — .gitignore
# Node.js 24 · TypeScript 5.9 · pnpm workspaces · React + Vite · Express
# =============================================================================

# -----------------------------------------------------------------------------
# Dependências
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js

# -----------------------------------------------------------------------------
# Build e compilação
# -----------------------------------------------------------------------------
dist/
build/
out/
out-tsc/
tmp/
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Variáveis de ambiente e segredos
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
# NÃO ignorar .env.example — deve ir para o repositório
!.env.example

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -----------------------------------------------------------------------------
# Cache
# -----------------------------------------------------------------------------
.cache/
.parcel-cache/
.turbo/
.eslintcache
.stylelintcache
*.cache

# -----------------------------------------------------------------------------
# Sistema operacional
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# IDEs e editores
# -----------------------------------------------------------------------------
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.sublime-workspace
*.sublime-project
.project
.classpath
.settings/
*.launch
.c9/
.cursor/

# -----------------------------------------------------------------------------
# Cobertura de testes
# -----------------------------------------------------------------------------
coverage/
*.lcov
.nyc_output/

# -----------------------------------------------------------------------------
# Arquivos temporários
# -----------------------------------------------------------------------------
*.tmp
*.temp
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Replit — arquivos de plataforma (não relevantes para outros ambientes)
# -----------------------------------------------------------------------------
.replit
.replitignore
.local/
attached_assets/

# -----------------------------------------------------------------------------
# Banco de dados local
# -----------------------------------------------------------------------------
*.sqlite
*.sqlite3
*.db
*.db-shm
*.db-wal

# -----------------------------------------------------------------------------
# Expo / React Native (não usado, mas prevenção)
# -----------------------------------------------------------------------------
.expo/
.expo-shared/

# -----------------------------------------------------------------------------
# Outros
# -----------------------------------------------------------------------------
.vercel
.netlify
.output/
typings/
connect.lock
libpeerconnection.log
testem.log
