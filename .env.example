# =============================================================================
# KaraoKê Queue — Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o arquivo .env no repositório.
# =============================================================================

# -----------------------------------------------------------------------------
# Banco de Dados (OBRIGATÓRIO)
# -----------------------------------------------------------------------------
# String de conexão PostgreSQL no formato:
#   postgresql://usuario:senha@host:porta/nome_do_banco
DATABASE_URL=postgresql://postgres:senha@localhost:5432/karaoke_queue

# -----------------------------------------------------------------------------
# Segurança (OBRIGATÓRIO)
# -----------------------------------------------------------------------------
# Chave secreta usada para assinar cookies de sessão do operador.
# Use uma string longa e aleatória. Exemplo:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=troque-por-uma-chave-secreta-longa-e-aleatoria

# Credenciais usadas somente para criar o primeiro operador quando ele não existe.
# A senha deve ter no mínimo 12 caracteres. Não use valores de exemplo em produção.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=troque-por-uma-senha-forte-com-12-ou-mais-caracteres
ADMIN_DISPLAY_NAME=Operador

# -----------------------------------------------------------------------------
# YouTube Data API v3 (OPCIONAL)
# -----------------------------------------------------------------------------
# Chave de API do Google Cloud com a YouTube Data API v3 habilitada.
# Se omitida, a busca de músicas retorna um resultado de demonstração
# em vez de consultar o YouTube de verdade.
# Obtenha em: https://console.cloud.google.com/apis/library/youtube.googleapis.com
YOUTUBE_API_KEY=

# -----------------------------------------------------------------------------
# Servidor (OPCIONAL — geralmente configurado pelo ambiente de execução)
# -----------------------------------------------------------------------------
# Porta em que o servidor Express vai escutar.
# Em produção, esta variável é geralmente injetada pela plataforma de deploy.
PORT=8080

# Ambiente de execução: development | production
NODE_ENV=development

# Origem pública exata, sem barra final. Necessária apenas se front e API
# estiverem em origens diferentes; no deploy único, a origem é inferida.
APP_ORIGIN=http://localhost:5173

# Nível dos logs estruturados: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
