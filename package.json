{
  "name": "workspace",
  "version": "0.0.0",
  "packageManager": "pnpm@10.17.1",
  "engines": { "node": ">=20 <25" },
  "license": "MIT",
  "scripts": {
    "preinstall": "node ./scripts/enforce-pnpm.mjs",
    "build": "pnpm run typecheck && pnpm -r --filter \"!./artifacts/mockup-sandbox\" --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "lint": "eslint artifacts/api-server/src artifacts/karaoke-queue/src --max-warnings 0",
    "test": "vitest run",
    "format:check": "prettier --check ."
  },
  "private": true,
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "prettier": "^3.8.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
